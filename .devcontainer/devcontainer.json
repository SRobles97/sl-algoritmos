{
  "name": "sl-analytics",
  "image": "ghcr.io/srobles97/sl-analytics:latest",
  "workspaceFolder": "/workspaces/sl-analytics",
  "mounts": [
    "source=sl-analytics-venv-shadow,target=/workspaces/sl-analytics/.venv,type=volume"
  ],
  "postCreateCommand": "pip install -e .",
  "forwardPorts": [8888],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
